@model IEnumerable<BioLife.Domain.Entities.Review>

@{
    ViewData["Title"] = "Manage Reviews";
    var search = ViewBag.Search as string;
    var page = ViewBag.Page as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<main>
    <div class="container-fluid px-4">
        <h1 class="mt-4">Reviews</h1>
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item active">Reviews</li>
        </ol>

        @if (TempData["SuccessMessage"] is not null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-comments me-1"></i>
                Review list
            </div>
            <div class="card-body">
                <form method="get" asp-action="Index" class="row g-2 mb-3">
                    <div class="col-md-8">
                        <input type="text" name="search" value="@search" class="form-control" placeholder="Search by comment, product, or user..." />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary">Search</button>
                        <a asp-action="Index" class="btn btn-secondary">Clear</a>
                    </div>
                </form>

                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>User</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var review in Model)
                            {
                                <tr>
                                    <td>@review.Product?.Name</td>
                                    <td>@review.AppUser?.UserName</td>
                                    <td>@review.Rating.ToString("0.#")</td>
                                    <td style="max-width:420px;">@review.Comment</td>
                                    <td>@review.CreatedDate.ToString("MMM dd, yyyy")</td>
                                    <td class="text-end">
                                        <form asp-action="Delete" asp-route-id="@review.Id" method="post" onsubmit="return confirm('Delete this review?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i>
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No reviews found.</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (totalPages > 1)
                {
                    <nav aria-label="Review pages">
                        <ul class="pagination justify-content-center">
                            @if (page > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@(page - 1)">Previous</a>
                                </li>
                            }

                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@i">@i</a>
                                </li>
                            }

                            @if (page < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@(page + 1)">Next</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</main>
