@model BasketViewModel

@{
    ViewData["Title"] = "Basket";
}

<div class="page-contain has-header-offset">
    <div id="main-content" class="main-content">
        <div class="container sm-margin-top-50px xs-margin-top-30px">
            <div class="biolife-title-box biolife-title-box__icon-at-top-style">
                <span class="icon-at-top biolife-icon icon-organic"></span>
                <h3 class="main-title">Basket</h3>
            </div>

            @if (Model is null || !Model.Items.Any())
            {
                <p class="text-center">Your basket is empty.</p>
                <p class="text-center">
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-bold">Continue shopping</a>
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="shop_table cart-form">
                        <thead>
                            <tr>
                                <th class="product-name">Product</th>
                                <th class="product-price">Price</th>
                                <th class="product-quantity">Quantity</th>
                                <th class="product-subtotal">Subtotal</th>
                                <th class="product-remove">Remove</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="product-name">
                                        <div class="cart-item">
                                            <div class="thumb">
                                                <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? Url.Content("~/assets/images/products/p-11.jpg") : item.ImageUrl)" alt="@item.ProductName" width="80" height="80">
                                            </div>
                                            <span class="title">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="product-price">£@item.Price.ToString("0.00")</td>
                                    <td class="product-quantity">
                                        <form asp-action="UpdateQuantity" method="post" class="quantity-form">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="input-qty" />
                                            <button type="submit" class="btn btn-thin">Update</button>
                                        </form>
                                    </td>
                                    <td class="product-subtotal">£@item.SubTotal.ToString("0.00")</td>
                                    <td class="product-remove">
                                        <form asp-action="Remove" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-thin">Remove</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="row sm-margin-top-30px">
                    <div class="col-lg-6 col-md-6 col-xs-12">
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-bold">Continue shopping</a>
                    </div>
                    <div class="col-lg-6 col-md-6 col-xs-12 text-right">
                        <p class="cart-total">Total: <strong>£@Model.Total.ToString("0.00")</strong></p>
                        <form asp-action="Clear" method="post" class="clear-cart-form">
                            <button type="submit" class="btn btn-thin">Clear basket</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
