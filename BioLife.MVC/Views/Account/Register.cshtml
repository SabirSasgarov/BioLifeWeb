@model BioLife.MVC.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<!--Hero Section-->
<div class="hero-section hero-background">
    <h1 class="page-title">Register</h1>
</div>

<!--Navigation section-->
<div class="container">
    <nav class="biolife-nav">
        <ul>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="permal-link">Home</a></li>
            <li class="nav-item"><span class="current-page">Register</span></li>
        </ul>
    </nav>
</div>

<div class="page-contain login-page" style="margin-top: 30px; margin-bottom: 50px;">
    <div id="main-content" class="main-content">
        <div class="container mt-5 mb-5">
            <div class="row justify-content-center" style="display: flex;">
                <div class="col-md-6 col-lg-5" style="margin: 0 auto;">
                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px;">
                        <div class="card-body p-4">
                            <h2 class="text-center mb-4" style="text-align: center; margin-bottom: 20px;">Register</h2>
                            <form asp-action="Register" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                
                                <div class="form-group mb-3" style="margin-bottom: 15px;">
                                    <label asp-for="FullName" class="form-label">Username</label>
                                    <input asp-for="FullName" class="form-control txt-input" id="FullName" name="FullName" required placeholder="Choose a username" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                                <div class="form-group mb-3" style="margin-bottom: 15px;">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    <input asp-for="Email" class="form-control txt-input" id="Email" name="Email" required placeholder="Enter your email" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="form-group mb-3" style="margin-bottom: 15px;">
                                    <label asp-for="Password" class="form-label">Password</label>
                                    <input asp-for="Password" class="form-control txt-input" id="Password" name="Password" required placeholder="Create a password" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                <div class="form-group mb-4" style="margin-bottom: 20px;">
                                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                                    <input asp-for="ConfirmPassword" class="form-control txt-input" id="ConfirmPassword" name="ConfirmPassword" required placeholder="Confirm your password" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>
                                
                                <button type="submit" class="btn btn-submit btn-bold" style="width: 100%; padding: 10px; background-color: #7faf51; color: white; border: none; font-weight: bold;">Register</button>
                            </form>
                            <div class="text-center mt-3" style="text-align: center; margin-top: 20px;">
                                <p class="mb-0">Already have an account? <a asp-controller="Account" asp-action="Login" style="color: #7faf51;">Login here</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js" integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42fQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
}