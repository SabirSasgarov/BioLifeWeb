@model BioLife.MVC.Models.TwoFactorViewModel

@{
    ViewData["Title"] = "Two-Factor Verification";
}

<!--Hero Section-->
<div class="hero-section hero-background">
    <h1 class="page-title">Two-Factor Verification</h1>
</div>

<!--Navigation section-->
<div class="container">
    <nav class="biolife-nav">
        <ul>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="permal-link">Home</a></li>
            <li class="nav-item"><span class="current-page">Log in Verification</span></li>
        </ul>
    </nav>
</div>

<div class="page-contain login-page" style="margin-top: 30px; margin-bottom: 50px;">
    <div id="main-content" class="main-content">
        <div class="container">
            <div class="row justify-content-center d-flex" style="display: flex;">
                <div class="col-md-6 col-lg-4" style="margin: 0 auto;">
                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px;">
                        <div class="card-body p-4">
                            <h2 class="text-center mb-4" style="text-align: center; margin-bottom: 20px;">Verify Code</h2>
                            <p class="text-center" style="margin-bottom: 15px; color: #666;">Enter the verification code sent to your email.</p>
                            <form asp-action="TwoFactorVerify" method="post">
                                <input type="hidden" asp-for="ReturnUrl" />
                                <input type="hidden" asp-for="RememberMe" />
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                <div class="form-group mb-3" style="margin-bottom: 15px;">
                                    <label asp-for="Code" class="form-label">Verification Code</label>
                                    <input asp-for="Code" class="form-control txt-input" required placeholder="Enter 6-digit code" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="Code" class="text-danger"></span>
                                </div>
                                <button type="submit" class="btn btn-submit btn-bold" style="width: 100%; padding: 10px; background-color: #7faf51; color: white; border: none; font-weight: bold;">Verify</button>
                            </form>
                            <form asp-action="ResendTwoFactorCode" method="post" style="text-align: center; margin-top: 15px;">
                                <button type="submit" style="background: none; border: none; color: #7faf51; text-decoration: underline; cursor: pointer;">Resend Code</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
