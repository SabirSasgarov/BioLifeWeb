@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<!--Hero Section-->
<div class="hero-section hero-background">
    <h1 class="page-title">Confirmation</h1>
</div>

<!--Navigation section-->
<div class="container">
    <nav class="biolife-nav">
        <ul>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="permal-link">Home</a></li>
            <li class="nav-item"><span class="current-page">Confirmation</span></li>
        </ul>
    </nav>
</div>

<div class="page-contain login-page" style="margin-top: 30px; margin-bottom: 50px;">
    <div id="main-content" class="main-content">
        <div class="container">
            <div class="row justify-content-center d-flex" style="display: flex;">
                <div class="col-md-6 col-lg-5" style="margin: 0 auto;">
                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px; text-align: center;">
                        <div class="card-body p-4">
                            <h2 class="mb-4" style="margin-bottom: 20px; color: #7faf51;">Check your email</h2>
                            <p style="margin-bottom: 20px; font-size: 16px;">
                                Please check your email to reset your password.
                            </p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-submit" style="padding: 10px 25px; background-color: #7faf51; color: white; text-decoration: none; border-radius: 3px; font-weight: bold;">Return to Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
