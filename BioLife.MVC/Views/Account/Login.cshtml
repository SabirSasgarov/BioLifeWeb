@model BioLife.MVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<!--Hero Section-->
<div class="hero-section hero-background">
    <h1 class="page-title">Login</h1>
</div>

<!--Navigation section-->
<div class="container">
    <nav class="biolife-nav">
        <ul>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="permal-link">Home</a></li>
            <li class="nav-item"><span class="current-page">Login</span></li>
        </ul>
    </nav>
</div>

<div class="page-contain login-page" style="margin-top: 30px; margin-bottom: 50px;">
    <div id="main-content" class="main-content">
        <div class="container">
            <div class="row justify-content-center d-flex" style="display: flex;">
                <div class="col-md-6 col-lg-4" style="margin: 0 auto;">
                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px;">
                        <div class="card-body p-4">
                            <h2 class="text-center mb-4" style="text-align: center; margin-bottom: 20px;">Login</h2>
                            <form asp-action="Login" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                <div class="form-group mb-3" style="margin-bottom: 15px;">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    <input asp-for="Email" class="form-control txt-input" id="Email" name="Email" required placeholder="Enter your email" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="form-group mb-3" style="margin-bottom: 15px;">
                                    <label asp-for="Password" class="form-label">Password</label>
                                    <input asp-for="Password" class="form-control txt-input" id="Password" name="Password" required placeholder="Enter your password" style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                <div class="form-check mb-3" style="margin-bottom: 15px;">
                                    <input asp-for="RememberMe" class="form-check-input" id="RememberMe" name="RememberMe" value="true" />
                                    <label class="form-check-label" asp-for="RememberMe">Remember me</label>
                                    <span asp-validation-for="RememberMe" class="text-danger"></span>
                                </div>
                                <button type="submit" class="btn btn-submit btn-bold" style="width: 100%; padding: 10px; background-color: #7faf51; color: white; border: none; font-weight: bold;">Login</button>
                            </form>

                            <form asp-controller="Account" asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                                <button type="submit" name="provider" value="Google" class="btn btn-google" style="width: 100%; padding: 10px; margin-top: 10px; background-color: #db4437; color: white; border: none; font-weight: bold;">Login with Google</button>
                            </form>


                            <div class="text-center mt-3" style="text-align: center; margin-top: 20px;">
                                <p class="mb-0">Don't have an account? <a asp-controller="Account" asp-action="Register" style="color: #7faf51;">Register here</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js" integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42fQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
}