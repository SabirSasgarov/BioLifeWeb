@model BioLife.MVC.Models.ProfileIndexViewModel
@{
    ViewData["Title"] = "My Profile";
}

<!--Hero Section-->
<div class="hero-section hero-background">
    <h1 class="page-title">My Profile</h1>
</div>

<!--Navigation section-->
<div class="container">
    <nav class="biolife-nav">
        <ul>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="permal-link">Home</a></li>
            <li class="nav-item"><span class="current-page">Profile Profile</span></li>
        </ul>
    </nav>
</div>

<div class="page-contain">
    <div id="main-content" class="main-content" style="padding-top: 30px; padding-bottom: 50px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-4">
                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px; text-align: center;">
                        <div class="profile-image mb-3">
                            @if (!string.IsNullOrEmpty(Model.ProfileImage))
                            {
                                <img src="@Model.ProfileImage" alt="Profile Image" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover;" />
                            }
                            else
                            {
                                <img src="~/assets/images/user-default.png" alt="Profile Image" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover;" />
                            }
                        </div>
                        <h3>@Model.FullName</h3>
                        <p class="text-muted">@Model.Email</p>

                        <div class="mt-4" style="margin-top: 20px;">
                            <a asp-action="Edit" class="btn btn-submit btn-bold" style="width: 100%; padding: 10px; background-color: #7faf51; color: white; border: none; margin-bottom: 10px;">Edit Profile</a>
                            <a asp-action="ChangeEmail" class="btn btn-submit" style="width: 100%; padding: 10px; background-color: #333; color: white; border: none; margin-bottom: 10px;">Change Email</a>
                            <a asp-action="ChangePassword" class="btn btn-submit" style="width: 100%; padding: 10px; background-color: #333; color: white; border: none; margin-bottom: 10px;">Change Password</a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8 col-md-8">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success" style="background-color: #d4edda; color: #155724; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <div class="card shadow-sm mb-4" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px; margin-bottom: 30px;">
                        <h4>Security Settings</h4>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center" style="display: flex; justify-content: space-between; margin-bottom: 15px;">
                            <div>
                                <strong>Two-Factor Authentication</strong>
                                <p class="text-muted" style="margin-bottom:0;">Add an extra layer of security to your account.</p>
                            </div>
                            <form asp-action="ToggleTwoFA" method="post">
                                @if (Model.TwoFactorEnabled)
                                {
                                    <button type="submit" class="btn btn-danger" style="padding: 8px 15px; background: #dc3545; color: white; border: none;">Disable 2FA</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-success" style="padding: 8px 15px; background: #28a745; color: white; border: none;">Enable 2FA</button>
                                }
                            </form>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-4" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px; margin-bottom: 30px;">
                        <h4>Newsletter & Updates</h4>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center" style="display: flex; justify-content: space-between; margin-bottom: 15px;">
                            <div>
                                <strong>BioLife Newsletter</strong>
                                <p class="text-muted" style="margin-bottom:0;">Receive latest offers and updates.</p>
                            </div>
                            <form asp-action="ToggleSubscription" method="post">
                                @if (Model.IsSubscribed)
                                {
                                    <button type="submit" class="btn btn-danger" style="padding: 8px 15px; background: #dc3545; color: white; border: none;">Unsubscribe</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-success" style="padding: 8px 15px; background: #28a745; color: white; border: none;">Subscribe</button>
                                }
                            </form>
                        </div>
                    </div>

                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px;">
                        <div class="d-flex justify-content-between align-items-center mb-3" style="display: flex; justify-content: space-between;">
                            <h4 style="margin: 0;">Recent Orders</h4>
                            <a asp-action="Orders" style="color: #7faf51;">View All Orders</a>
                        </div>
                        <hr />
                        @if (Model.RecentOrders.Any())
                        {
                            <table class="table" style="width: 100%; text-align: left;">
                                <thead>
                                    <tr>
                                        <th style="padding: 10px; border-bottom: 1px solid #ddd;">Order #</th>
                                        <th style="padding: 10px; border-bottom: 1px solid #ddd;">Date</th>
                                        <th style="padding: 10px; border-bottom: 1px solid #ddd;">Total</th>
                                        <th style="padding: 10px; border-bottom: 1px solid #ddd;">Status</th>
                                        <th style="padding: 10px; border-bottom: 1px solid #ddd;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td style="padding: 10px; border-bottom: 1px solid #eee;">#@order.Id</td>
                                            <td style="padding: 10px; border-bottom: 1px solid #eee;">@order.CreatedDate.ToString("MMM dd, yyyy")</td>
                                            <td style="padding: 10px; border-bottom: 1px solid #eee;">£@order.TotalAmount</td>
                                            <td style="padding: 10px; border-bottom: 1px solid #eee;">@order.OrderStatus</td>
                                            <td style="padding: 10px; border-bottom: 1px solid #eee;"><a asp-action="OrderDetails" asp-route-id="@order.Id" style="color: #7faf51;">Details</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">You have no recent orders yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>