@model BioLife.MVC.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="hero-section hero-background">
    <h1 class="page-title">Change Password</h1>
</div>

<div class="container">
    <nav class="biolife-nav">
        <ul>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="permal-link">Home</a></li>
            <li class="nav-item"><a asp-action="Index" class="permal-link">Profile</a></li>
            <li class="nav-item"><span class="current-page">Change Password</span></li>
        </ul>
    </nav>
</div>

<div class="page-contain" style="margin-top: 30px; margin-bottom: 50px;">
    <div id="main-content" class="main-content">
        <div class="container">
            <div class="row justify-content-center d-flex" style="display: flex;">
                <div class="col-md-6 col-lg-5" style="margin: 0 auto;">
                    <div class="card shadow-sm" style="border: 1px solid #e1e1e1; padding: 25px; border-radius: 5px;">
                        <h2 class="text-center mb-4" style="text-align: center; margin-bottom: 20px;">Change Password</h2>

                        <form asp-action="ChangePassword" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger" style="color: #dc3545; margin-bottom: 15px;"></div>

                            <div class="form-group mb-3" style="margin-bottom: 15px;">
                                <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                                <input asp-for="CurrentPassword" type="password" class="form-control txt-input" required style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                <span asp-validation-for="CurrentPassword" class="text-danger" style="color: #dc3545;"></span>
                            </div>

                            <div class="form-group mb-3" style="margin-bottom: 15px;">
                                <label asp-for="NewPassword" class="form-label">New Password</label>
                                <input asp-for="NewPassword" type="password" class="form-control txt-input" required style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                <span asp-validation-for="NewPassword" class="text-danger" style="color: #dc3545;"></span>
                            </div>

                            <div class="form-group mb-3" style="margin-bottom: 15px;">
                                <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
                                <input asp-for="ConfirmNewPassword" type="password" class="form-control txt-input" required style="width: 100%; padding: 10px; border: 1px solid #ddd;" />
                                <span asp-validation-for="ConfirmNewPassword" class="text-danger" style="color: #dc3545;"></span>
                            </div>

                            <div style="margin-top: 20px; text-align: center;">
                                <button type="submit" class="btn btn-submit" style="width: 100%; padding: 10px; background-color: #7faf51; color: white; border: none; font-weight: bold;">Change Password</button>
                                <a asp-action="Index" style="display: block; margin-top: 10px; color: #7faf51;">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>